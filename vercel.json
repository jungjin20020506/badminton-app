{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python", "config": { "includeFiles": "app/**" } },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/photos/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
